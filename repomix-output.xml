<file path="client/index.html">
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NeuroMotorik Screener — Vision-Based Health Assessment</title>
    <meta name="description" content="Sistem skrining neuro-motorik berbasis AI untuk deteksi dini Stroke, Parkinson, dan Sarcopenia menggunakan webcam dan MediaPipe Pose.">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">

    <!-- MediaPipe Pose -->
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/pose/pose.js" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/@mediapipe/camera_utils/camera_utils.js" crossorigin="anonymous"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <!-- jsPDF + html2canvas (for PDF export) -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js" defer></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js" defer></script>

    <link rel="stylesheet" href="css/style.css?v=3">
</head>
<body>

    <!-- ═══ SIDEBAR ═══════════════════════════════════════════ -->
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-brand">
            <div class="brand-icon">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 2a4 4 0 0 0-4 4v2a4 4 0 0 0 8 0V6a4 4 0 0 0-4-4z"/>
                    <path d="M6 10v1a6 6 0 0 0 12 0v-1"/>
                    <path d="M12 17v4"/>
                    <path d="M8 21h8"/>
                </svg>
            </div>
            <div class="brand-text">
                <span class="brand-name">NeuroMotorik</span>
                <span class="brand-tag">Screening v2.0</span>
            </div>
        </div>

        <nav class="sidebar-nav">
            <button class="nav-item active" data-view="dashboard" onclick="app.showView('dashboard')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/></svg>
                <span>Dashboard</span>
            </button>
            <button class="nav-item" data-view="assessment" onclick="app.showView('assessment')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="5" r="2"/><path d="M10 22V18L7 15V11l5-3 5 3v4l-3 3v4"/></svg>
                <span>Assessment</span>
            </button>
            <button class="nav-item" data-view="reports" onclick="app.showView('reports')">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
                <span>Laporan</span>
            </button>
        </nav>

        <div class="sidebar-footer">
            <div class="connection-indicator" id="conn-indicator">
                <span class="conn-dot"></span>
                <span class="conn-text" id="conn-text">Connecting...</span>
            </div>
            <button class="btn btn-sm" id="notif-btn" style="display:none;margin-top:8px;width:100%;background:var(--blue);color:white;border:none;border-radius:6px;padding:6px;cursor:pointer;font-size:11px">🔔 Enable Notifications</button>
        </div>
    </aside>

    <!-- ═══ MAIN CONTENT ═══════════════════════════════════════ -->
    <main class="main-content">

        <!-- ═══ DASHBOARD VIEW ═══════════════════════════════ -->
        <section id="view-dashboard" class="view active">
            <header class="view-header">
                <div>
                    <h1>Dashboard</h1>
                    <p class="subtitle">Sistem Skrining Multi-Anomali Neuro-Motorik</p>
                </div>
                <div class="header-badge">LIVE</div>
            </header>

            <!-- Stats Cards -->
            <div class="stats-row">
                <div class="stat-card glass">
                    <div class="stat-icon blue">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value counter" data-target="0" id="stat-patients">0</span>
                        <span class="stat-label">Total Pasien</span>
                    </div>
                </div>
                <div class="stat-card glass">
                    <div class="stat-icon purple">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value counter" data-target="0" id="stat-sessions">0</span>
                        <span class="stat-label">Total Sesi</span>
                    </div>
                </div>
                <div class="stat-card glass">
                    <div class="stat-icon green">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" id="stat-normal">0</span>
                        <span class="stat-label">Normal</span>
                    </div>
                </div>
                <div class="stat-card glass">
                    <div class="stat-icon yellow">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" id="stat-monitor">0</span>
                        <span class="stat-label">Monitor</span>
                    </div>
                </div>
                <div class="stat-card glass">
                    <div class="stat-icon red">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
                    </div>
                    <div class="stat-info">
                        <span class="stat-value" id="stat-referal">0</span>
                        <span class="stat-label">Referal</span>
                    </div>
                </div>
            </div>

            <!-- Quick Start -->
            <div class="card glass">
                <div class="card-header">
                    <h2>Mulai Assessment Baru</h2>
                </div>
                <div class="form-grid">
                    <div class="form-group">
                        <label>Patient ID</label>
                        <input type="text" id="patient-id" placeholder="contoh: PT-2026-001" value="">
                    </div>
                    <div class="form-group">
                        <label>Usia (tahun)</label>
                        <input type="number" id="patient-age" placeholder="contoh: 65" min="0" max="120" value="">
                    </div>
                    <div class="form-group">
                        <label>Instruksi Klinis</label>
                        <select id="instruction-select">
                            <option value="raise_hands">Angkat Kedua Tangan — Deteksi Stroke</option>
                            <option value="stand_still">Berdiri Diam — Deteksi Parkinson</option>
                            <option value="sit_to_stand">Duduk ke Berdiri — Deteksi Sarcopenia</option>
                        </select>
                    </div>
                    <div class="form-group form-actions">
                        <button class="btn btn-primary btn-lg" id="btn-start" onclick="app.startAssessment()">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="5 3 19 12 5 21 5 3"/></svg>
                            Mulai
                        </button>
                    </div>
                </div>
                <div style="margin-top:16px;padding-top:16px;border-top:1px solid var(--border)">
                    <button class="btn btn-primary btn-lg" style="width:100%;background:linear-gradient(135deg,#8b5cf6,#3b82f6)" onclick="app.startSequential()">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        Full Assessment (3-in-1) — Semua Tes Sekaligus
                    </button>
                </div>
            </div>

            <!-- Evidence Info -->
            <div class="card glass evidence-info">
                <div class="card-header">
                    <h2>📊 Basis Klinis</h2>
                </div>
                <div class="evidence-grid">
                    <div class="evidence-item">
                        <div class="evidence-icon stroke-icon">🧠</div>
                        <div class="evidence-content">
                            <strong>Stroke — Asymmetry Index</strong>
                            <p>Whitall et al. (2006), Kim et al. (2014)<br>ASI ≤ 0.08 Normal | 0.08–0.15 Monitor | &gt; 0.15 Referal</p>
                        </div>
                    </div>
                    <div class="evidence-item">
                        <div class="evidence-icon parkinson-icon">🫨</div>
                        <div class="evidence-content">
                            <strong>Parkinson — Tremor Analysis</strong>
                            <p>PPMI Dataset, Jankovic (2008)<br>Rest tremor 3.5–7.0 Hz | Amplitude &gt; 0.003 suspicious</p>
                        </div>
                    </div>
                    <div class="evidence-item">
                        <div class="evidence-icon sarcopenia-icon">🦴</div>
                        <div class="evidence-content">
                            <strong>Sarcopenia — Sit-to-Stand</strong>
                            <p>Bohannon (2006), Guralnik et al. (2000)<br>Age-stratified thresholds (5XSST normative data)</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ ASSESSMENT VIEW ═══════════════════════════════ -->
        <section id="view-assessment" class="view">
            <header class="view-header">
                <div>
                    <h1 id="assess-title">Assessment</h1>
                    <p class="subtitle" id="assess-patient">Pasien: ---</p>
                </div>
                <!-- Sequential Step Indicator -->
                <div id="seq-indicator" class="seq-indicator" style="display:none">
                    <div class="seq-step active" id="seq-step-1"><span class="seq-num">1</span><span class="seq-label">Angkat</span></div>
                    <div class="seq-arrow">→</div>
                    <div class="seq-step" id="seq-step-2"><span class="seq-num">2</span><span class="seq-label">Berdiri</span></div>
                    <div class="seq-arrow">→</div>
                    <div class="seq-step" id="seq-step-3"><span class="seq-num">3</span><span class="seq-label">Duduk</span></div>
                    <span class="seq-progress" id="seq-progress">0/3</span>
                </div>
                <div class="assess-controls">
                    <span class="timer" id="timer">00:00</span>
                    <span class="frame-badge" id="frame-counter">Frame: 0</span>
                    <button class="btn btn-danger btn-sm" id="btn-stop" onclick="app.stopAssessment()">Selesai</button>
                </div>
            </header>

            <div class="assessment-layout">
                <!-- Left: Video + Skeleton -->
                <div class="video-column">
                    <div class="video-wrapper glass">
                        <video id="webcam" autoplay playsinline muted></video>
                        <canvas id="skeleton-canvas"></canvas>
                        <div id="pose-guide" class="pose-guide hidden">
                            <div class="guide-text" id="guide-text"></div>
                        </div>
                        <div id="status-badge" class="status-overlay normal">
                            <span class="pulse-dot"></span>
                            <span id="status-text">Normal</span>
                        </div>
                    </div>
                    <!-- Confidence + Progress -->
                    <div class="progress-confidence-row">
                        <div class="confidence-indicator">
                            <span class="confidence-label">Confidence:</span>
                            <div class="confidence-track">
                                <div id="confidence-fill" class="confidence-fill"></div>
                            </div>
                            <span id="confidence-value" class="confidence-value">0%</span>
                        </div>
                        <div class="progress-wrapper">
                            <div class="progress-track">
                                <div id="progress-bar" class="progress-fill"></div>
                            </div>
                            <span id="progress-text" class="progress-label">0%</span>
                        </div>
                    </div>
                </div>

                <!-- Right: Live Metrics -->
                <div class="metrics-column">
                    <!-- ASI Card -->
                    <div class="metric-card glass">
                        <div class="mc-header">
                            <h3>Indeks Asimetri</h3>
                            <span class="mc-badge normal" id="asi-badge">Normal</span>
                        </div>
                        <div class="mc-big-value" id="asi-value">0.000</div>
                        <div class="threshold-bar">
                            <div class="tb-segment green" style="width:40%"></div>
                            <div class="tb-segment yellow" style="width:35%"></div>
                            <div class="tb-segment red" style="width:25%"></div>
                        </div>
                        <div class="tb-labels"><span>0</span><span>0.08</span><span>0.15</span><span>0.30</span></div>
                        <div class="mc-detail">
                            <div>Sudut Kiri: <strong id="angle-L">-</strong>&deg;</div>
                            <div>Sudut Kanan: <strong id="angle-R">-</strong>&deg;</div>
                        </div>
                    </div>

                    <!-- ASI Chart -->
                    <div class="metric-card glass">
                        <div class="mc-header"><h3>ASI Time Series</h3></div>
                        <canvas id="chart-asi" height="130"></canvas>
                    </div>

                    <!-- Tremor Chart -->
                    <div class="metric-card glass">
                        <div class="mc-header"><h3>Power Spectral Density</h3></div>
                        <canvas id="chart-psd" height="150"></canvas>
                        <div class="mc-detail">
                            <div>Freq: <strong id="freq-dom">-</strong> Hz</div>
                            <div>Amplitudo: <strong id="tremor-amp">-</strong></div>
                        </div>
                    </div>

                    <!-- Sit-to-Stand -->
                    <div class="metric-card glass" id="sts-card" style="display:none">
                        <div class="mc-header"><h3>Transisi Duduk-Berdiri</h3></div>
                        <div class="phase-track">
                            <div class="phase-dot active" id="ph-sitting">Duduk</div>
                            <div class="phase-line"></div>
                            <div class="phase-dot" id="ph-transition">Transisi</div>
                            <div class="phase-line"></div>
                            <div class="phase-dot" id="ph-standing">Berdiri</div>
                        </div>
                        <div class="mc-big-value" id="sts-dur">- s</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- ═══ REPORTS VIEW ══════════════════════════════════ -->
        <section id="view-reports" class="view">
            <header class="view-header">
                <div>
                    <h1>Laporan Assessment</h1>
                    <p class="subtitle">Ringkasan hasil skrining klinis</p>
                </div>
            </header>

            <div id="report-empty" class="empty-state glass">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                    <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
                </svg>
                <p>Selesaikan sesi assessment untuk melihat laporan di sini.</p>
            </div>

            <div id="report-content" class="report-result" style="display:none"></div>
        </section>
    </main>

    <!-- ═══ STATUS BAR ════════════════════════════════════════ -->
    <footer class="statusbar">
        <div class="sb-left">
            <span class="sb-item"><span class="dot dot-red" id="sb-dot"></span> <span id="sb-text">Offline</span></span>
            <span class="sb-divider"></span>
            <span class="sb-item" id="sb-ping">Ping: — ms</span>
        </div>
        <div class="sb-center">
            <span class="sb-item" id="sb-fps">FPS: 0</span>
            <span class="sb-divider"></span>
            <span class="sb-item" id="sb-frame">Frame: 0</span>
        </div>
        <div class="sb-right">
            <span class="sb-item" id="sb-server">Server: —</span>
        </div>
    </footer>

    <!-- Scripts -->
    <script src="js/websocket-client.js?v=5"></script>
    <script src="js/skeleton-renderer.js?v=2"></script>
    <script src="js/chart-manager.js?v=2"></script>
    <script src="js/main.js?v=12"></script>

</body>
</html>
</file>

